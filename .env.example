# =============================================================================
# Brave Search MCP Server — Environment Variables
# =============================================================================

# --- API Keys ---------------------------------------------------------------
# Brave Search API uses separate subscription plans, each with its own key.
# Set the keys for the plans you have subscribed to.
# BRAVE_API_KEY is used as fallback for any endpoint without a specific key.

# Default / fallback key (Free Search plan or any single-key setup)
BRAVE_API_KEY=your_api_key_here

# Search plan key — covers: web, news, images, videos, local POIs, llm-context
# (https://api-dashboard.search.brave.com/app/subscriptions/subscribe)
# BRAVE_SEARCH_API_KEY=

# Free AI plan key — covers: summarizer (limited free tier)
# BRAVE_AI_API_KEY=

# Pro AI plan key — covers: summarizer (deprecated Pro AI subscription)
# BRAVE_PRO_AI_API_KEY=

# Answers plan key — covers: chat completions / AI answers
# BRAVE_ANSWERS_API_KEY=

# Autosuggest plan key — covers: /suggest/search
# BRAVE_AUTOSUGGEST_API_KEY=

# Spellcheck plan key — covers: /spellcheck/search
# BRAVE_SPELLCHECK_API_KEY=

# --- API Base URL ------------------------------------------------------------
# Override to route all requests through a local caching proxy
# BRAVE_API_BASE_URL=http://localhost:8080

# --- Transport ---------------------------------------------------------------
# BRAVE_MCP_TRANSPORT=stdio

# --- HTTP Transport (only needed when BRAVE_MCP_TRANSPORT=http) --------------
# BRAVE_MCP_PORT=8080
# BRAVE_MCP_HOST=0.0.0.0

# --- Logging -----------------------------------------------------------------
# BRAVE_MCP_LOG_LEVEL=info

# --- Tool Allow/Deny Lists ---------------------------------------------------
# Space-separated tool names
# BRAVE_MCP_ENABLED_TOOLS=
# BRAVE_MCP_DISABLED_TOOLS=

# --- Stateless Mode (HTTP transport) ----------------------------------------
# BRAVE_MCP_STATELESS=false
