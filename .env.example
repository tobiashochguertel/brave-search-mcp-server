# Required: Your Brave Search API key (https://brave.com/search/api/)
BRAVE_API_KEY=your_api_key_here

# Optional: Override API base URL to use a local caching proxy
# BRAVE_API_BASE_URL=http://localhost:8080

# Optional: Transport type (stdio or http)
# BRAVE_MCP_TRANSPORT=stdio

# Optional: HTTP transport settings
# BRAVE_MCP_PORT=8080
# BRAVE_MCP_HOST=0.0.0.0

# Optional: Log level (debug, info, warning, error)
# BRAVE_MCP_LOG_LEVEL=info

# Optional: Tool allow/deny lists (space-separated tool names)
# BRAVE_MCP_ENABLED_TOOLS=
# BRAVE_MCP_DISABLED_TOOLS=

# Optional: Stateless mode for HTTP transport
# BRAVE_MCP_STATELESS=false
