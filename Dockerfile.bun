FROM oven/bun:1-alpine AS base
WORKDIR /app

# Install production dependencies only
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile --production

# Copy source (Bun runs TypeScript natively — no build step needed)
COPY src/ src/
COPY tsconfig.json ./

USER bun
EXPOSE 8080/tcp

ENTRYPOINT ["bun", "src/entrypoints/bun.ts"]
